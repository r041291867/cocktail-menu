---
import "./cocktailItem/styles.scss";
import "./shotIcon/styles.scss";
import "@/styles/tags.scss";
import { toChinese } from "@/data/engToCht";
import { getAlcoholShots, getShotList } from "@/data/recipeUtils";
import GlassWithLiquid from "@/components/GlassWithLiquid";

const { cocktail, recipe } = Astro.props;

function capitalize(string: string) {
  return string.charAt(0).toUpperCase() + string.slice(1);
}

function getGlassIcon(glass: string | undefined): string | null {
  const map: Record<string, string> = {
    coupe: "/images/glass/ic-glass-coupe.svg",
    lowball: "/images/glass/ic-glass-rocks.svg",
    highball: "/images/glass/ic-glass-highball.svg",
    collins: "/images/glass/ic-glass-collins.svg",
    martini: "/images/glass/ic-glass-martini.svg",
    nick_nora: "/images/glass/ic-glass-nick-nora.svg",
    hurricane: "/images/glass/ic-glass-hurricane.svg",
  };

  return glass ? (map[glass.toLowerCase()] ?? null) : null;
}
---

{
  recipe && (
    <div class="cocktail__outer" data-recipe-name={cocktail.nameEng}>
      <GlassWithLiquid
        glass={recipe.glass}
        liquidColor={cocktail.color}
        liquidOpacity={cocktail.opacity}
        style={{ width: 80 }}
      />

      <div class="cocktail__frame">
        <div class="cocktail__main">
          <div class="cocktail__name">
            <div class="cocktail__cht handwrite-ch">{cocktail.nameCht}</div>
            <div class="cocktail__eng handwrite-en">{cocktail.nameEng}</div>
          </div>

          <div class="cocktail__stars">
            {getShotList(recipe.alcohol ? getAlcoholShots(recipe.alcohol) : recipe.shots).map((status, index) => (
              <div class="shot-icon__frame" style="width:16px;height:16px;" data-shot={index}>
                <div class={`shot-icon status-${status}`} />
              </div>
            ))}
          </div>
        </div>

        <div class="cocktail__ingredients--ch handwrite-ch">
          {recipe.ingredients.map((str: string) => toChinese(str)).join(" / ")}
        </div>
        <div class="cocktail__ingredients handwrite-en">
          {recipe.ingredients.map((str: string) => capitalize(str)).join(" / ")}
        </div>

        {recipe.tags?.length > 0 && (
          <div class="tags-list">
            {recipe.tags.map((tag: string) => (
              <span class="tags handwrite-ch" style="font-size: 12px">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
