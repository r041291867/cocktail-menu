{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "extends": ["eslint:recommended", "plugin:react/recommended"],
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
